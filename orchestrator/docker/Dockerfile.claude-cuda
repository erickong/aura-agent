FROM nvidia/cuda:12.4.1-base-ubuntu22.04

# Build-time mirror args — empty by default (use default sources).
# Pass these to accelerate downloads in your region:
#   --build-arg APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn
#   --build-arg PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
#   --build-arg NPM_REGISTRY=https://registry.npmmirror.com
ARG APT_MIRROR=""
ARG PIP_INDEX_URL=""
ARG NPM_REGISTRY=""

ENV DEBIAN_FRONTEND=noninteractive
ENV NPM_CONFIG_PREFIX=/usr/local
ENV PATH=/usr/local/bin:$PATH

# apt — all system packages in one layer, restore sources after install
RUN if [ -n "$APT_MIRROR" ]; then \
        find /etc/apt -name '*.list' -exec sed -i.bak \
            -e "s|http://archive.ubuntu.com|$APT_MIRROR|g" \
            -e "s|http://security.ubuntu.com|$APT_MIRROR|g" \
            -e "s|http://ports.ubuntu.com|$APT_MIRROR|g" \
            {} + ; \
    fi \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        gnupg \
        build-essential \
        python3 \
        python3-pip \
        python3-venv \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm --version \
    && if [ -n "$APT_MIRROR" ]; then \
        find /etc/apt -name '*.bak' -exec sh -c 'mv "$1" "${1%.bak}"' _ {} \; ; \
    fi \
    && useradd -m -u 1000 -s /bin/bash aura \
    && rm -rf /var/lib/apt/lists/*

# pip — -i flag is per-command, never persisted
RUN if [ -n "$PIP_INDEX_URL" ]; then \
        _pip_extra="-i $PIP_INDEX_URL" ; \
    else \
        _pip_extra="" ; \
    fi \
    && python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel $_pip_extra \
    && python3 -m pip install --no-cache-dir $_pip_extra \
        numpy \
        pandas \
        scipy \
        scikit-learn \
        torch \
        torchvision \
        torchaudio

# npm — --registry flag is per-command, never persisted
RUN if [ -n "$NPM_REGISTRY" ]; then \
        _npm_reg="--registry $NPM_REGISTRY" ; \
    else \
        _npm_reg="" ; \
    fi \
    && npm install $_npm_reg -g @anthropic-ai/claude-code

WORKDIR /workspace
RUN chown aura:aura /workspace
USER aura
