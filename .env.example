# Aura Agent optional config example.
#
# Normal setup:
#   aura setup
#
# That writes ~/.aura/config.env, or %USERPROFILE%\.aura\config.env on Windows.
# Use this file only if you want a custom override:
#   aura --config .env.example start --task-file tasks/example_mission.md

# Layer 1 model API. The default endpoint is DeepSeek's Anthropic-compatible API.
AURA_API_KEY=sk-your-api-key-here
AURA_API_BASE_URL=https://api.deepseek.com/anthropic
AURA_API_MODEL=deepseek-v4-pro
AURA_API_MAX_TOKENS=4096
AURA_API_PROVIDER=deepseek

# Main loop timing.
AURA_CYCLE_INTERVAL=300
AURA_DEEP_REVIEW_INTERVAL=12
AURA_LLM_DEAD_THROTTLE=300

# Layer 2 worker backend.
# Options:
#   claude - run workers through Claude Code CLI (`claude -p @task.md`)
#   ds_code     - run workers through ds-code CLI (`ds-code run`)
AURA_LAYER2_BACKEND=claude

# Worker limits.
AURA_MAX_CONCURRENT_TASKS=2
AURA_TASK_BUDGET=30
AURA_MAX_TURNS=50

# Worker resource guard. Percent limits are per Aura worker process tree.
# Set a numeric limit to 0 to disable that specific check.
AURA_WORKER_RESOURCE_GUARD=1
AURA_WORKER_RESOURCE_POLL_SECONDS=10
AURA_WORKER_RESOURCE_AVG_WINDOW_SECONDS=180
AURA_WORKER_RESOURCE_VIOLATION_STRIKES=3
AURA_WORKER_MAX_CPU_PERCENT=80
AURA_WORKER_MAX_SYSTEM_MEMORY_PERCENT=80
AURA_WORKER_MAX_GPU_UTIL_PERCENT=80
AURA_WORKER_MAX_GPU_MEMORY_PERCENT=80
AURA_WORKER_MAX_SYSTEM_MEMORY_GB=0
AURA_WORKER_MIN_SYSTEM_MEMORY_FREE_GB=0
AURA_WORKER_MAX_GPU_MEMORY_GB=0
AURA_WORKER_MIN_GPU_MEMORY_FREE_GB=0
AURA_WORKER_CUDA_VISIBLE_DEVICES=

# ds-code backend settings. Used only when AURA_LAYER2_BACKEND=ds_code.
AURA_DEEPSEEK_API_KEY=
AURA_DSCODE_MODEL=deepseek-v4-pro
AURA_DSCODE_MAX_TURNS=50
AURA_DSCODE_BASE_URL=

# Runtime optimizations and reports.
AURA_FILE_CACHE=1
AURA_FILE_CACHE_TTL=60
AURA_TASK_SUMMARY=1
AURA_TASK_CLEANUP_AGE=7
